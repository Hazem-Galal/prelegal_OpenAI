# OpenAI API key — REQUIRED for the LLM field-extraction feature. Server-side only.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the models used by the chat feature (backend/app/chat.py).
# CHAT_MODEL drives the conversational reply; EXTRACTION_MODEL drives the
# cheaper/faster structured field extraction. Both have sane defaults below.
OPENAI_CHAT_MODEL=gpt-4.1
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini
